{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/npm", {
      "npmPublish": false,
      "tarballDir": "dist"
    }],
    ["@semantic-release/exec", {
      "prepareCmd": "docker run --rm -v $PWD:/home/node/app -e DISABLE_ELECTRON_SANDBOX=1 puro/electron-secure-builder bash build-deb.sh"
    }],
    ["@semantic-release/github", {
      "assets": [
        {"path": "out/puro_*.deb", "label": "Debian Package"}
      ]
    }]
  ]
}